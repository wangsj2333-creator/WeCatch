{
  "name": "WeCatch",
  "version": "1.0.0",
  "manifest_version": 3,
  "description": "Capture WeChat Official Account comments and auto-classify via LLM",
  "permissions": ["storage"],
  "host_permissions": [
    "https://mp.weixin.qq.com/*",
    "http://localhost:8080/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://mp.weixin.qq.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dashboard.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
